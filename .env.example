# Copy to .env.local:  copy .env.example .env.local

# MongoDB (required)
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/ide"

# App URL (GitHub OAuth callback base)
NEXTAUTH_URL=http://localhost:3000

# Clerk (required) — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx

# Clerk paths — your Next.js routes (NOT *.accounts.dev portal URLs)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# GitHub repo import (callback: http://localhost:3000/api/github/callback)
AUTH_GITHUB_ID=Ov23liP81wbt6xbnMcQG
AUTH_GITHUB_SECRET=25131634d0cd14b8a086b1f7f9aab518ea9ce680

# AI features (optional — requires local Ollama when enabled)
NEXT_PUBLIC_ENABLE_AI=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=codellama:latest

# Feature flags (optional)
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_BETA_FEATURES=true

# Optional: collaboration WebSocket
# NEXT_PUBLIC_WS_URL=ws://localhost:3001
